{
  "name": "saathi-setu",
  "version": "0.1.3",
  "private": true,
  "description": "Desktop integration foundation for fetching Saathi portal data and syncing it with Tally.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "web": "node src/server.js",
    "help": "node src/index.js help",
    "check": "node --check src/index.js && node --check src/config.js && node --check src/json-path.js && node --check src/saathi-client.js && node --check src/saathi-billing-client.js && node --check src/saathi-signing.js && node --check src/env-store.js && node --check src/error-log.js && node --check src/tally-log.js && node --check src/response-archive.js && node --check src/company-settings.js && node --check src/app-db.js && node --check src/tally-client.js && node --check src/server.js && node --check public/app.js && node --check electron/main.cjs",
    "orders": "node src/index.js pending-orders",
    "fetch:lot": "node src/index.js fetch-lot",
    "pull:lot": "node src/index.js pull-lot",
    "dist": "electron-builder --win --ia32",
    "dist:win32": "electron-builder --win --ia32",
    "dist:win64": "electron-builder --win --x64",
    "dist:protected": "npm run dist:protected:win32 && npm run dist:protected:win64",
    "dist:protected:win32": "node scripts/build-protected.js --ia32",
    "dist:protected:win64": "node scripts/build-protected.js --x64"
  },
  "build": {
    "appId": "com.arinfotech.sathiconnect",
    "productName": "Sathi Connect",
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "portable-license-flow/**/*",
      "config/**/*",
      "keys/**/*",
      ".env",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "src/**/*",
      "portable-license-flow/**/*",
      "public/**/*",
      "config/**/*",
      "keys/**/*",
      ".env"
    ],
    "directories": {
      "output": "release 0.0.1"
    },
    "artifactName": "${productName} Setup ${version} ${arch}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "public/assets/sathi-connect-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sathi Connect",
      "installerIcon": "public/assets/sathi-connect-icon.ico",
      "uninstallerIcon": "public/assets/sathi-connect-icon.ico",
      "installerHeaderIcon": "public/assets/sathi-connect-icon.ico"
    }
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.4.2"
  },
  "engines": {
    "node": ">=18"
  }
}
