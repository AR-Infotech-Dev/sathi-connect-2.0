# Copy this file to .env and fill the values locally.
# Do not commit real credentials.

SAATHI_BASE_URL=https://seedtrace.nic.in/inv-apis2
SAATHI_API_KEY=

# Header auth provided by SATHI admin.
SAATHI_CLIENT_ID=
SAATHI_CLIENT_SECRET=
# Use "sha512" only when SATHI gave you a plain password and expects SHA512(password)
# in the clientsecret header. Otherwise keep "plain".
SAATHI_CLIENT_SECRET_MODE=plain

# Common request defaults.
SAATHI_DEFAULT_OWNER_CODE=
SAATHI_DEFAULT_LOCATION_CODE=
SAATHI_DEFAULT_STATE_CODE=27

# Runtime behavior.
SAATHI_TIMEOUT_MS=30000
SAATHI_RETRY_COUNT=2

# Legacy/generic resource map retained for future non-billing endpoints.
SAATHI_RESOURCES_FILE=config/resources.example.json

TALLY_URL=http://127.0.0.1:9000
TALLY_COMPANY_NAME=
TALLY_TIMEOUT_MS=15000

# Activation request email. For Gmail, use an app password.
ACTIVATION_EMAIL_SMTP_HOST=smtp.gmail.com
ACTIVATION_EMAIL_SMTP_PORT=465
ACTIVATION_EMAIL_USER=sathiconnects@gmail.com
ACTIVATION_EMAIL_APP_PASSWORD=diek cvif zykr chox
ACTIVATION_EMAIL_TO=sathiconnects@gmail.com
ACTIVATION_EMAIL_FROM=sathiconnects@